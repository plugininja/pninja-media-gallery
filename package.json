{
  "name": "pninja-media-gallery",
  "version": "1.0.0",
  "description": "Pninja Media Gallery – responsive galleries for WordPress",
  "license": "GPL-2.0-or-later",
  "private": true,
  "files": [
      "assets",
      "core",
      "includes",
      "languages",
      "models",
      "templates",
      "index.php",
      "pninja-media-gallery.php",
      "readme.txt",
      "uninstall.php"
  ],
  "scripts": {
    "build:tokens": "node scripts/build-tokens.js",
    "dev-admin": "webpack --watch --config webpack.dev.config.js",
    "dev-hot": "npm run dev-admin",
    "build-admin": "webpack --config webpack.prod.config.js",
    "start": "npm run build:tokens && webpack --watch --config webpack.dev.config.js",
    "clean-maps": "find . \\( -name \"*.map\" -o -name \".DS_Store\" \\) -type f -delete",
    "lint": "eslint source/ --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint source/ --ext .js,.jsx,.ts,.tsx --fix",
    "make-pot": "wp i18n make-pot . languages/pninja-media-gallery.pot --domain=pninja-media-gallery --slug=pninja-media-gallery --exclude=node_modules --package-name=\"Pninja Media Gallery\" --headers='{\"Report-Msgid-Bugs-To\":\"https://wordpress.org/support/plugin/pninja-media-gallery\"}'",
    "test:php": "wp-env run tests-cli phpunit",
    "test:php:start": "wp-env start && wp-env run tests-cli phpunit",

    "build": "npm run build:tokens && npm run build-admin && npm run clean-maps",

    "build:zip":     "npm run build && npm run build:zip:wp && npm run build:zip:dev",
    "build:zip:wp":  "wp-scripts plugin-zip",
    "build:zip:dev": "node scripts/strip-premium__premium_only.js && node scripts/zip-free__premium_only.js",

    "strip-premium": "node scripts/strip-premium__premium_only.js",
    "zip:free":      "node scripts/zip-free__premium_only.js"
  },
  "devDependencies": {
        "@types/node": "^22.15.17",
        "@types/wordpress__block-editor": "^11.5.17",
        "@wordpress/block-editor": "~15.19.0",
        "@wordpress/components": "^30.5.0",
        "@wordpress/element": "^6.23.0",
        "@wordpress/env": "^10.39.0",
        "@wordpress/i18n": "^5.6.0",
        "@wordpress/scripts": "^31.4.0",
        "autoprefixer": "^10.4.21",
        "concurrently": "^8.2.2",
        "copy-webpack-plugin": "^13.0.0",
        "cssnano": "^7.0.7",
        "glob": "^11.0.2",
        "postcss": "^8.5.3",
        "postcss-cli": "^11.0.1",
        "postcss-preset-env": "^10.4.0",
        "typescript": "^5.6.3",
        "webpack-cli": "^6.0.1"
    },
    "dependencies": {
        "@reduxjs/toolkit": "^2.3.0",
        "clsx": "^2.1.1",
        "react-redux": "^9.1.2",
        "react-router-dom": "^7.6.1",
        "sass": "^1.77.8"
    }
}
