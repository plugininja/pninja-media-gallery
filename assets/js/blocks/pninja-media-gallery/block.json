{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "pninja-media-gallery/gallery",
    "version": "1.0.0",
    "title": "Pninja Media Gallery",
    "category": "pninja-media-gallery",
    "icon": "format-gallery",
    "description": "Embed a Pninja Media Gallery into your content",
    "keywords": ["gallery", "images", "photos", "masonry"],
    "textdomain": "pninja-media-gallery",
    "supports": {
        "html": false,
        "align": ["wide", "full"],
        "spacing": {
            "margin": true,
            "padding": true
        }
    },
    "attributes": {
        "id": {
            "type": "number"
        },
        "title": {
            "type": "string",
            "default": ""
        }
    },
    "editorScript": "file:./index.js"
}
